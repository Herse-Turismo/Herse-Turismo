                <button class="book-nav-btn" id="futbolNavPrev" onclick="navFutbolPassport(-1)">&#8249;</button>
                <span class="book-nav-lbl" id="futbolNavLbl">1 / 1</span>
                <button class="book-nav-btn" id="futbolNavNext" onclick="navFutbolPassport(1)">&#8250;</button>
