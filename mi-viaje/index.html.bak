</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script>
    const SUPA_URL = 'https://yuukqdcjitxhaeevjxjb.supabase.co';
    const SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl1dWtxZGNqaXR4aGFlZXZqeGpiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY3OTE2NjQsImV4cCI6MjA5MjM2NzY2NH0.meXXmlipCt6w10S_XEOOBEXAPtA84LuURnT0V3JB-Mw';
    const { createClient } = supabase;
    const _db = createClient(SUPA_URL, SUPA_KEY);

    let TRIP_DATE = new Date('2025-08-15T08:30:00-03:00');
    let _tickInterval;
    let _isAdmin = false;

    /* ── THEME ── */
    (function () {
        const saved = localStorage.getItem('herse_theme') || 'light';
        document.documentElement.dataset.theme = saved;
        const btn = document.getElementById('themeBtn');
        if (btn) btn.textContent = saved === 'dark' ? '☀️' : '🌙';
    })();

    function toggleTheme() {
        const html = document.documentElement;
        const isDark = html.dataset.theme === 'dark';
        html.dataset.theme = isDark ? 'light' : 'dark';
        const btn = document.getElementById('themeBtn');
        if (btn) btn.textContent = isDark ? '🌙' : '☀️';
        localStorage.setItem('herse_theme', isDark ? 'light' : 'dark');
    }

    /* ── MAIN: AUTH + DATA ── */
    (async () => {
        const { data: { session } } = await _db.auth.getSession();
        if (!session) { window.location.href = '/login'; return; }

        const user = session.user;

        const { data: _perfAdmin } = await _db.from('perfiles').select('is_admin').eq('id', user.id).single();
        if (_perfAdmin?.is_admin) {
            document.getElementById('btnAdmin').classList.add('visible');
            _isAdmin = true;
        } else {
            document.getElementById('mainDashboard').style.display = 'none';
            document.getElementById('pendingState').style.display  = 'none';
            document.getElementById('proximamente').style.display  = 'block';
            return;
        }

        const raw  = user.user_metadata?.nombre || user.email.split('@')[0].replace(/[._-]/g, ' ');
        const name = raw.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
        document.querySelectorAll('.name').forEach(el => el.textContent = name);
        const ini = document.getElementById('avatarInitial');
        if (ini) ini.textContent = name.charAt(0).toUpperCase();

        const { data: viajes } = await _db
            .from('viajes')
            .select('*, documentos(*)')
            .eq('activo', true)
            .order('fecha_salida', { ascending: true })
            .limit(1);

        if (viajes?.length > 0) {
            const v = viajes[0];
            TRIP_DATE = new Date(v.fecha_salida);
            updateTripUI(v);
            checkCheckinReminder(v.fecha_salida, v.vuelo_ida);
        } else {
            document.getElementById('mainDashboard').style.display = 'none';
            document.getElementById('pendingState').style.display  = 'block';
            clearInterval(_tickInterval);
        }

        loadHistorial();
        initPasaporte(user.id);

        const { data: fid } = await _db.from('fidelizacion').select('*').maybeSingle();
        if (fid) updateLoyalty(fid);

        tick();
        _tickInterval = setInterval(tick, 1000);

        const pct = fid ? Math.min((fid.viajes_completados / 5) * 100, 100) : 0;
        setTimeout(() => { const b = document.getElementById('loyaltyBar'); if (b) b.style.width = pct + '%'; }, 500);
    })();

    /* ── LOGOUT ── */
    function logout() {
        _db.auth.signOut().then(() => { window.location.href = '/login'; });
    }

    /* ── HELPERS DE FECHA ── */
    function fmtDate(d) { return d.toLocaleDateString('es-AR', { day: 'numeric', month: 'short' }); }
    function fmtDateTime(d) {
        return d.toLocaleDateString('es-AR', { day: 'numeric', month: 'short' }) + ' · ' +
               d.toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' });
    }

    /* ── FLAG MAP ── */
    const FLAG_MAP = {
        brasil:'🇧🇷', brazil:'🇧🇷', argentina:'🇦🇷', espana:'🇪🇸', spain:'🇪🇸',
        italia:'🇮🇹', italy:'🇮🇹', francia:'🇫🇷', france:'🇫🇷',
        mexico:'🇲🇽', alemania:'🇩🇪', germany:'🇩🇪', portugal:'🇵🇹',
        eeuu:'🇺🇸', usa:'🇺🇸', uruguay:'🇺🇾', england:'🏴󠁧󠁢󠁥󠁮󠁧󠁿',
        grecia:'🇬🇷', japon:'🇯🇵', turquia:'🇹🇷', egipto:'🇪🇬',
    };
    function getFlag(text) {
        const k = text.toLowerCase()
            .replace(/[áéíóúñü]/g, c => ({á:'a',é:'e',í:'i',ó:'o',ú:'u',ñ:'n',ü:'u'}[c] || c));
        return Object.entries(FLAG_MAP).find(([key]) => k.includes(key))?.[1] || '🌍';
    }

    /* ── UPDATE TRIP UI ── */
    function updateTripUI(v) {
        const sd = new Date(v.fecha_salida);
        const ed = new Date(v.fecha_regreso);

        const ctd = document.getElementById('cardTripDest');
        if (ctd) ctd.textContent = v.destino;

        document.querySelectorAll('.countdown-footer').forEach(f => {
            f.textContent = fmtDate(sd) + ' → ' + fmtDate(ed);
        });

        const dest = document.getElementById('mosaicTripDest');
        if (dest) dest.textContent = v.destino;

        const fc = document.getElementById('tripFlagCircle');
        if (fc) fc.textContent = getFlag(v.destino);

        const vs = document.querySelector('.mt-val-salida');  if (vs) vs.textContent = fmtDateTime(sd);
        const vr = document.querySelector('.mt-val-regreso'); if (vr) vr.textContent = fmtDateTime(ed);
        const vp = document.querySelector('.mt-val-pax');     if (vp) vp.textContent = v.pasajeros + (v.pasajeros === 1 ? ' adulto' : ' adultos');
        const vh = document.querySelector('.mt-val-hotel');   if (vh) vh.textContent = v.hotel || '—';
    }

    /* ── HISTORIAL ── */
    async function loadHistorial() {
        const { data } = await _db.from('viajes')
            .select('destino,fecha_salida,fecha_regreso')
            .eq('activo', false)
            .order('fecha_salida', { ascending: false });
        initViajePassport(data || []);
        renderRecentTrips(data || []);
    }

    function renderRecentTrips(viajes) {
        const wrap = document.getElementById('recentTrips');
        if (!wrap) return;
        if (!viajes.length) return;
        wrap.innerHTML = viajes.slice(0, 3).map(v => {
            const sd = new Date(v.fecha_salida);
            const ed = new Date(v.fecha_regreso);
            const flag = getFlag(v.destino);
            const d1 = sd.toLocaleDateString('es-AR',{day:'numeric',month:'short',year:'numeric'});
            const d2 = ed.toLocaleDateString('es-AR',{day:'numeric',month:'short',year:'numeric'});
            return `<div class="recent-trip-item">
                <div class="rtrip-thumb">${flag}</div>
                <div style="flex:1;min-width:0">
                    <div class="rtrip-name">${v.destino}</div>
                    <div class="rtrip-dates">${d1} – ${d2}</div>
                </div>
                <span class="rtrip-badge"><i class="fas fa-check" style="font-size:.55rem"></i> Completado</span>
            </div>`;
        }).join('');
    }

    /* ── LOYALTY ── */
    function updateLoyalty(fid) {
        const done = fid.viajes_completados || 0;
        let level, icon, nextLevel, hint, nextBenefit, nextBenefitSub;
        if (done >= 5) {
            level = 'Elite VIP'; icon = '🏆';
            nextLevel = '— Máximo'; hint = '¡Sos parte de nuestra élite de viajeros!';
            nextBenefit = 'Upgrade de habitación'; nextBenefitSub = 'Ya disponible en tu nivel Elite VIP';
        } else if (done >= 3) {
            level = 'Viajero'; icon = '✈️';
            nextLevel = '→ Elite VIP'; hint = `${5 - done} viaje${5 - done > 1 ? 's' : ''} más para Elite VIP`;
            nextBenefit = 'Upgrade de habitación'; nextBenefitSub = 'Disponible desde nivel Elite VIP';
        } else {
            level = 'Explorador'; icon = '🌱';
            nextLevel = '→ Viajero'; hint = `${3 - done} viaje${3 - done > 1 ? 's' : ''} más para Viajero`;
            nextBenefit = 'Check-in anticipado'; nextBenefitSub = 'Disponible desde nivel Viajero';
        }
        const lbl    = document.getElementById('fidLevelLabel');
        const cnt    = document.getElementById('fidCountLabel');
        const badge  = document.getElementById('fidTierBadge');
        const next   = document.getElementById('fidNextTier');
        const curLbl = document.getElementById('fidCurrentTierLbl');
        const hint_  = document.getElementById('fidProgHint');
        const nb     = document.getElementById('fidNextBenefit');
        const nbs    = document.getElementById('fidNextBenefitSub');
        if (lbl)    lbl.textContent = level;
        if (cnt)    cnt.textContent = done * 250;
        if (badge)  badge.querySelector('span').textContent = icon;
        if (next)   next.textContent = nextLevel;
        if (curLbl) curLbl.textContent = level;
        if (hint_)  hint_.textContent = hint;
        if (nb)     nb.textContent = nextBenefit;
        if (nbs)    nbs.textContent = nextBenefitSub;
    }

    function updateDocs() {}

    /* ── COUNTDOWN ── */
    function pad(n) { return String(n).padStart(2, '0'); }
    function tick() {
        const diff = TRIP_DATE - new Date();
        if (diff <= 0) {
            ['cd-d','cd-h','cd-m','cd-s'].forEach(id => { const e = document.getElementById(id); if (e) e.textContent = '00'; });
            clearInterval(_tickInterval);
            return;
        }
        const vals = [
            Math.floor(diff / 864e5),
            Math.floor((diff % 864e5) / 36e5),
            Math.floor((diff % 36e5) / 6e4),
            Math.floor((diff % 6e4) / 1e3)
        ];
        ['cd-d','cd-h','cd-m','cd-s'].forEach((id, i) => {
            const el = document.getElementById(id);
            if (!el) return;
            const v = pad(vals[i]);
            if (el.textContent !== v) {
                el.classList.add('tick');
                setTimeout(() => el.classList.remove('tick'), 120);
                el.textContent = v;
            }
        });
    }

    /* ── CHECK-IN BANNER ── */
    function checkCheckinReminder(tripDate, vueloIda) {
        const key = `herse_chk_dismissed_${tripDate}`;
        if (localStorage.getItem(key)) return;
        const diff  = new Date(tripDate) - new Date();
        const hours = diff / 36e5;
        if (hours > 0 && hours <= 48) {
            const banner = document.getElementById('checkinBanner');
            const txt    = document.getElementById('checkinBannerText');
            const btn    = document.getElementById('btnCheckinDo');
            const h = Math.floor(hours);
            if (txt) txt.textContent = ` Tu vuelo ${vueloIda ? `(${vueloIda}) ` : ''}sale en ${h} hora${h !== 1 ? 's' : ''}. ¡Hace el check-in!`;
            if (banner) { banner.classList.add('show'); banner._dismissKey = key; }
            if (btn && vueloIda?.toUpperCase().includes('AR')) {
                btn.onclick = () => window.open('https://www.aerolineas.com.ar/check-in', '_blank');
            }
        }
    }
    function dismissCheckin() {
        const banner = document.getElementById('checkinBanner');
        if (banner) {
            if (banner._dismissKey) localStorage.setItem(banner._dismissKey, '1');
            banner.classList.remove('show');
        }
    }

    /* ── PASSPORT DATA ── */
    const PASAPORTE_DATA = {
        england:  { nombre:'Inglaterra', flag:'🏴󠁧󠁢󠁥󠁮󠁧󠁿', liga:'Premier League', estadios:[
            { id:'eng_anfield',      nombre:'Anfield',           equipo:'Liverpool FC' },
            { id:'eng_old_trafford', nombre:'Old Trafford',      equipo:'Manchester United' },
            { id:'eng_etihad',       nombre:'Etihad Stadium',    equipo:'Manchester City' },
            { id:'eng_emirates',     nombre:'Emirates Stadium',  equipo:'Arsenal FC' },
            { id:'eng_stamford',     nombre:'Stamford Bridge',   equipo:'Chelsea FC' },
            { id:'eng_wembley',      nombre:'Wembley Stadium',   equipo:'Selección Inglesa' },
        ]},
        spain:    { nombre:'España',     flag:'🇪🇸', liga:'La Liga', estadios:[
            { id:'esp_bernabeu',     nombre:'Santiago Bernabéu', equipo:'Real Madrid' },
            { id:'esp_camp_nou',     nombre:'Spotify Camp Nou',  equipo:'FC Barcelona' },
            { id:'esp_wanda',        nombre:'Metropolitano',     equipo:'Atlético de Madrid' },
            { id:'esp_mestalla',     nombre:'Mestalla',          equipo:'Valencia CF' },
            { id:'esp_san_mames',    nombre:'San Mamés',         equipo:'Athletic Bilbao' },
            { id:'esp_pizjuan',      nombre:'Sánchez-Pizjuán',  equipo:'Sevilla FC' },
        ]},
        italy:    { nombre:'Italia',     flag:'🇮🇹', liga:'Serie A', estadios:[
            { id:'ita_san_siro',     nombre:'San Siro',          equipo:'Inter / AC Milan' },
            { id:'ita_olimpico',     nombre:'Stadio Olimpico',   equipo:'Roma / Lazio' },
            { id:'ita_allianz',      nombre:'Allianz Stadium',   equipo:'Juventus FC' },
            { id:'ita_maradona',     nombre:'Stadio Maradona',   equipo:'SSC Napoli' },
            { id:'ita_bentegodi',    nombre:'Bentegodi',         equipo:'Verona / Chievo' },
        ]},
        germany:  { nombre:'Alemania',   flag:'🇩🇪', liga:'Bundesliga', estadios:[
            { id:'ger_signal',       nombre:'Signal Iduna Park', equipo:'Borussia Dortmund' },
            { id:'ger_allianz',      nombre:'Allianz Arena',     equipo:'Bayern München' },
            { id:'ger_volksparkst',  nombre:'Volksparkstadion',  equipo:'Hamburger SV' },
            { id:'ger_rheinenergie', nombre:'RheinEnergieStad.', equipo:'1. FC Köln' },
            { id:'ger_olympia',      nombre:'Olympiastadion',    equipo:'Hertha BSC' },
        ]},
        argentina:{ nombre:'Argentina',  flag:'🇦🇷', liga:'Liga Profesional', estadios:[
            { id:'arg_monumental',   nombre:'El Monumental',     equipo:'River Plate' },
            { id:'arg_bombonera',    nombre:'La Bombonera',      equipo:'Boca Juniors' },
            { id:'arg_cilindro',     nombre:'El Cilindro',       equipo:'Racing Club' },
            { id:'arg_gasometro',    nombre:'Nuevo Gasómetro',   equipo:'San Lorenzo' },
            { id:'arg_libertadores', nombre:'Libertadores Am.',  equipo:'Independiente' },
            { id:'arg_bosque',       nombre:'Est. Ciudad de LP', equipo:'Estudiantes LP' },
        ]},
        brazil:   { nombre:'Brasil',     flag:'🇧🇷', liga:'Brasileirão', estadios:[
            { id:'bra_maracana',     nombre:'Maracaná',          equipo:'Flamengo / Fluminense' },
            { id:'bra_morumbi',      nombre:'Morumbis',          equipo:'São Paulo FC' },
            { id:'bra_neo_quimica',  nombre:'Neo Química Arena', equipo:'Corinthians' },
            { id:'bra_mineirao',     nombre:'Mineirão',          equipo:'Atlético / Cruzeiro' },
            { id:'bra_beira_rio',    nombre:'Beira-Rio',         equipo:'Internacional' },
        ]},
    };

    const PASSPORT_KEYS = Object.keys(PASAPORTE_DATA);
    let _selladosSet    = new Set();
    let _passportUserId = null;

    /* ── VIAJE PASSPORT DATA ── */
    const VIAJE_PAGES = [
        {
            left:  { title:'América del Sur', icon:'🌎', items:[
                {id:'arg',nombre:'Argentina'},{id:'bra',nombre:'Brasil'},
                {id:'chi',nombre:'Chile'},{id:'col',nombre:'Colombia'},
                {id:'per',nombre:'Perú'},{id:'uru',nombre:'Uruguay'},
            ]},
            right: { title:'América del Norte', icon:'🌎', items:[
                {id:'mex',nombre:'México'},{id:'usa',nombre:'Estados Unidos'},{id:'can',nombre:'Canadá'},
            ]},
        },
        {
            left:  { title:'Europa', icon:'🌍', items:[
                {id:'esp',nombre:'España'},{id:'ita',nombre:'Italia'},
                {id:'fra',nombre:'Francia'},{id:'ale',nombre:'Alemania'},
                {id:'por',nombre:'Portugal'},
            ]},
            right: { title:'Europa (cont.)', icon:'🌍', items:[
                {id:'ing',nombre:'Inglaterra'},{id:'gre',nombre:'Grecia'},
                {id:'hol',nombre:'Holanda'},{id:'bel',nombre:'Bélgica'},
            ]},
        },
        {
            left:  { title:'Asia & Medio Oriente', icon:'🌏', items:[
                {id:'jpn',nombre:'Japón'},{id:'tai',nombre:'Tailandia'},
                {id:'tur',nombre:'Turquía'},{id:'dub',nombre:'Dubai'},
            ]},
            right: { title:'Oceanía & África', icon:'🌏', items:[
                {id:'aus',nombre:'Australia'},{id:'egy',nombre:'Egipto'},
                {id:'mar',nombre:'Marruecos'},{id:'nzl',nombre:'Nueva Zelanda'},
            ]},
        },
    ];
    let _viajeSelladosSet = new Set();
    let _viajeCurrentPage = 0;
    let _futbolCurrentTab = 0;
    let _futbolCurrentPage = 0;

    function matchesDestino(destino, pais) {
        const n = s => s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
        const d = n(destino), p = n(pais);
        return d.includes(p) || p.includes(d);
    }

    /* ── INIT PASSPORT ── */
    async function initPasaporte(userId) {
        _passportUserId = userId;
        const { data } = await _db.from('pasaporte_tribunero').select('estadio_id').eq('user_id', userId);
        if (data) data.forEach(r => _selladosSet.add(r.estadio_id));
        updatePasaporteCounter();
        initFutbolBook();
    }

    /* ── VIAJE PASSPORT ── */
    function initViajePassport(historialData) {
        _viajeSelladosSet = new Set();
        (historialData || []).forEach(v => {
            VIAJE_PAGES.forEach(pg => {
                [pg.left, pg.right].forEach(side => {
                    side.items.forEach(item => {
                        if (matchesDestino(v.destino, item.nombre)) _viajeSelladosSet.add(item.id);
                    });
                });
            });
        });
        const totalViaje = VIAJE_PAGES.reduce((s,p)=>s+p.left.items.length+p.right.items.length,0);
        const viajeCount = _viajeSelladosSet.size;
        const lbl = document.getElementById('viajeSellosLbl');
        if (lbl) lbl.textContent = `${viajeCount} / ${totalViaje}`;
        const bar = document.getElementById('viajeProgressBar');
        if (bar) bar.style.width = Math.round((viajeCount/totalViaje)*100) + '%';
        const mc = document.getElementById('viajeModalCount');
        if (mc) mc.textContent = `${viajeCount} / ${totalViaje} sellos`;
        _viajeCurrentPage = 0;
        renderViajeSpread(false, 0);
    }

    const STAMP_PALETTE = ['#1a6cff','#22c55e','#ef4444','#8b5cf6','#f97316','#0ea5e9','#ec4899','#eab308','#14b8a6','#6366f1'];

    function makeStampSVG(flag, name, color, visited) {
        const uid = 'sv' + (Math.random() * 99999 | 0);
        const c   = visited ? color : '#b5a282';
        const bg  = visited ? color + '18' : 'rgba(180,162,130,.06)';
        const op  = visited ? 1 : 0.38;
        const lbl = name.toUpperCase().substring(0, 13);
        return `<svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" style="overflow:visible;opacity:${op}">
            <defs><path id="${uid}" d="M 8,40 A 32,32 0 0,1 72,40"/></defs>
            <circle cx="40" cy="40" r="36" fill="${bg}" stroke="${c}" stroke-width="2.4" ${visited ? '' : 'stroke-dasharray="3 2"'}/>
            <circle cx="40" cy="40" r="28" fill="none" stroke="${c}" stroke-width="1.1" opacity=".5"/>
            <text font-size="7" font-weight="900" fill="${c}" font-family="system-ui,sans-serif" letter-spacing="1.8">
                <textPath href="#${uid}" startOffset="50%" text-anchor="middle">${lbl}</textPath>
            </text>
            <text x="40" y="52" text-anchor="middle" font-size="24" font-family="system-ui,sans-serif">${flag}</text>
            ${visited ? `<text x="40" y="70" text-anchor="middle" font-size="6.5" font-weight="900" fill="${c}" font-family="system-ui,sans-serif" letter-spacing="1.2">✶ SELLADO ✶</text>` : ''}
        </svg>`;
    }

    const PP_ROTS = [2,-4,3,-2,4,-3,1,-5,3,-1,2,-4,5,-2,1];

    function renderViajeSpread(animate, dir) {
        const spread = document.getElementById('viajeSpread');
        if (!spread) return;
        const pg = VIAJE_PAGES[_viajeCurrentPage];

        function buildSide(side, cls) {
            const items = side.items.map(item => {
                const s   = _viajeSelladosSet.has(item.id);
                const fl  = getFlag(item.nombre);
                const code = item.nombre.substring(0, 3).toUpperCase();
                const stampEl = s ? `<span class="stamp">VISADO</span>` : '';
                const btn = s
                    ? `<button class="stamp-btn done" disabled>✓ Sellado</button>`
                    : `<button class="stamp-btn" disabled>Próx.</button>`;
                return `<div class="country ${s ? 'stamped' : ''}">
                    ${stampEl}
                    <span class="country-flag-emoji">${fl}</span>
                    <div class="country-body">
                        <span class="code">${code}</span>
                        <span class="name">${item.nombre}</span>
                    </div>
                    ${btn}
                </div>`;
            }).join('');
            return `<div class="page ${cls}"><div class="page-title">${side.icon} ${side.title}</div>${items}</div>`;
        }

        if (animate) {
            spread.classList.add(dir > 0 ? 'anim-fwd' : 'anim-bck');
            setTimeout(() => spread.classList.remove('anim-fwd','anim-bck'), 280);
        }
        spread.innerHTML = `<div class="book-pages">${buildSide(pg.left,'left-page')}${buildSide(pg.right,'right-page')}</div>`;

        const total = VIAJE_PAGES.length;
        const lbl = document.getElementById('viajeNavLbl');
        if (lbl) lbl.textContent = `${_viajeCurrentPage + 1} / ${total}`;
        const prev = document.getElementById('viajeNavPrev');
        const next = document.getElementById('viajeNavNext');
        if (prev) prev.disabled = _viajeCurrentPage === 0;
        if (next) next.disabled = _viajeCurrentPage >= total - 1;
    }

    function navViajePassport(dir) {
        const total = VIAJE_PAGES.length;
        _viajeCurrentPage = Math.max(0, Math.min(total - 1, _viajeCurrentPage + dir));
        renderViajeSpread(true, dir);
    }

    /* ── FUTBOL BOOK ── */
    function initFutbolBook() {
        renderFutbolTabs();
        _futbolCurrentPage = 0;
        renderFutbolSpread(false, 0);
    }

    function renderFutbolTabs() {
        const tabs = document.getElementById('futbolTabs');
        if (!tabs) return;
        tabs.innerHTML = PASSPORT_KEYS.map((key, i) => {
            const p = PASAPORTE_DATA[key];
            return `<button class="league-tab-btn ${i === _futbolCurrentTab ? 'active' : ''}" onclick="selectFutbolTab(${i})">${p.flag} ${p.nombre}</button>`;
        }).join('');
    }

    function selectFutbolTab(idx) {
        _futbolCurrentTab = idx;
        _futbolCurrentPage = 0;
        document.querySelectorAll('#futbolTabs .league-tab-btn').forEach((t,i) => t.classList.toggle('active', i === idx));
        renderFutbolSpread(false, 0);
    }

    function renderFutbolSpread(animate, dir) {
        const spread = document.getElementById('futbolSpread');
        if (!spread) return;
        const pais = PASAPORTE_DATA[PASSPORT_KEYS[_futbolCurrentTab]];
        const perPage = 4;
        const totalPages = Math.max(1, Math.ceil(pais.estadios.length / perPage));
        const slice = pais.estadios.slice(_futbolCurrentPage * perPage, (_futbolCurrentPage + 1) * perPage);
        const left  = slice.slice(0, 2);
        const right = slice.slice(2, 4);

        function buildRow(e) {
            const v = _selladosSet.has(e.id);
            const stampEl = v ? `<span class="stamp">MATCH</span>` : '';
            const action = _isAdmin
                ? (v ? `<button class="stamp-btn done" disabled>✓ Sellado</button>`
                     : `<button class="stamp-btn" id="sbtn-${e.id}" onclick="sellarEstadio('${e.id}',this)">Sellar</button>`)
                : (v ? `<button class="stamp-btn done" disabled>✓ Visitado</button>` : '');
            return `<div class="stadium ${v ? 'stamped' : ''}" id="srow-${e.id}">
                ${stampEl}
                <div class="stadium-info">
                    <span class="stadium-icon">🏙️</span>
                    <div>
                        <div class="stadium-name">${e.nombre}</div>
                        <div class="stadium-club">${e.equipo}</div>
                    </div>
                </div>
                ${action}
            </div>`;
        }

        if (animate) {
            spread.classList.add(dir > 0 ? 'anim-fwd' : 'anim-bck');
            setTimeout(() => spread.classList.remove('anim-fwd','anim-bck'), 280);
        }
        const visitedLeague = pais.estadios.filter(e => _selladosSet.has(e.id)).length;
        const totalLeague   = pais.estadios.length;
        const pct = Math.round((visitedLeague / totalLeague) * 100);
        const complete = visitedLeague === totalLeague;
        const leagueHdr = complete
            ? `<div style="background:#fef9c3;border-radius:8px;padding:6px 9px;margin-bottom:9px;font-size:.7rem;font-weight:800;color:#854d0e;display:flex;align-items:center;gap:6px">
                   <i class="fas fa-trophy" style="color:#f59e0b"></i> ¡Completaste ${pais.nombre}!
               </div>`
            : `<div style="margin-bottom:9px">
                   <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
                       <span style="font-size:.62rem;font-weight:700;color:var(--text-muted)">${pais.liga}</span>
                       <span style="font-size:.68rem;font-weight:800;color:var(--accent)">${visitedLeague}/${totalLeague}</span>
                   </div>
                   <div style="height:4px;background:var(--border);border-radius:99px;overflow:hidden">
                       <div style="height:100%;width:${pct}%;background:var(--accent);border-radius:99px;transition:width .6s"></div>
                   </div>
               </div>`;
        const leftRows  = left.map(buildRow).join('');
        const rightRows = right.map(buildRow).join('');
        spread.innerHTML = `<div class="book-pages">
            <div class="page left-page"><div class="page-title">${pais.flag} ${pais.nombre}</div>${leagueHdr}${leftRows}</div>
            <div class="page right-page"><div style="height:42px"></div>${rightRows}</div>
        </div>`;

        const lbl = document.getElementById('futbolNavLbl');
        if (lbl) lbl.textContent = `${_futbolCurrentPage + 1} / ${totalPages}`;
        const prev = document.getElementById('futbolNavPrev');
        const next = document.getElementById('futbolNavNext');
        if (prev) prev.disabled = _futbolCurrentPage === 0;
        if (next) next.disabled = _futbolCurrentPage >= totalPages - 1;
    }

    function navFutbolPassport(dir) {
        const pais = PASAPORTE_DATA[PASSPORT_KEYS[_futbolCurrentTab]];
        const totalPages = Math.max(1, Math.ceil(pais.estadios.length / 4));
        _futbolCurrentPage = Math.max(0, Math.min(totalPages - 1, _futbolCurrentPage + dir));
        renderFutbolSpread(true, dir);
    }

    /* ── SELLAR ESTADIO ── */
    async function sellarEstadio(estadioId, btn) {
        if (_selladosSet.has(estadioId) || !_passportUserId) return;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        const { error } = await _db.from('pasaporte_tribunero').insert({ user_id: _passportUserId, estadio_id: estadioId });
        if (error) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-stamp"></i> Sellar'; return; }
        _selladosSet.add(estadioId);
        const row = document.getElementById(`srow-${estadioId}`);
        if (row) {
            row.classList.add('stamped');
            if (!row.querySelector('.stamp')) {
                const st = document.createElement('span');
                st.className = 'stamp';
                st.textContent = 'MATCH';
                row.insertBefore(st, row.firstChild);
            }
            const b = row.querySelector('.stamp-btn');
            if (b) { b.textContent = '✓ Sellado'; b.disabled = true; b.classList.add('done'); }
        }
        updatePasaporteCounter();
    }

    /* ── COUNTER ── */
    function updatePasaporteCounter() {
        const total = Object.values(PASAPORTE_DATA).reduce((s, p) => s + p.estadios.length, 0);
        const count = _selladosSet.size;
        const el = document.getElementById('pasaporteCount');
        if (el) el.textContent = `${count} / ${total} estadios`;
        const lbl = document.getElementById('futbolSellosLbl');
        if (lbl) lbl.textContent = `${count} / ${total}`;
        const bar = document.getElementById('futbolProgressBar');
        if (bar) bar.style.width = Math.round((count/total)*100) + '%';
    }

    /* ── PASSPORT MODALS ── */
    function _coverClickThen(selector, cb) {
        const cover = document.querySelector(selector);
        if (!cover) { cb(); return; }
        cover.style.transform = 'scale(0.96) rotate(-3deg)';
        cover.style.transition = 'transform 90ms ease';
        setTimeout(() => { cover.style.transform = ''; cover.style.transition = ''; cb(); }, 110);
    }
    function openViajeModal() {
        _coverClickThen('.pcover.green', () => {
            renderViajeSpread(false, 0);
            document.getElementById('viajeModalOverlay').classList.add('open');
            document.body.style.overflow = 'hidden';
            setTimeout(() => {
                const p3d = document.getElementById('passportViaje3d');
                if (p3d) p3d.classList.add('open');
            }, 80);
        });
    }
    function closeViajeModal() {
        const p3d = document.getElementById('passportViaje3d');
        if (p3d) p3d.classList.remove('open');
        setTimeout(() => {
            document.getElementById('viajeModalOverlay').classList.remove('open');
            document.body.style.overflow = '';
        }, 650);
    }
    function openFutbolModal() {
        _coverClickThen('.pcover.purple', () => {
            initFutbolBook();
            document.getElementById('futbolModalOverlay').classList.add('open');
            document.body.style.overflow = 'hidden';
            setTimeout(() => {
                const p3d = document.getElementById('passportFutbol3d');
                if (p3d) p3d.classList.add('open');
            }, 80);
        });
    }
    function closeFutbolModal() {
        const p3d = document.getElementById('passportFutbol3d');
        if (p3d) p3d.classList.remove('open');
        setTimeout(() => {
            document.getElementById('futbolModalOverlay').classList.remove('open');
            document.body.style.overflow = '';
        }, 650);
    }
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') { closeViajeModal(); closeFutbolModal(); }
    });

    /* CSS maneja hover/active en .pcover, no se necesita JS para tilt */

    /* ── SERVICE WORKER ── */
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => { navigator.serviceWorker.register('/sw.js').catch(() => {}); });
    }
</script>

</body>
</html>
