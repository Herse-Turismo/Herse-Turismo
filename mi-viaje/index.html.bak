<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Mi Viaje · Herse Turismo</title>
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Mi Viaje Herse">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#003366">
    <meta name="description" content="Tu portal personal de viaje con Herse Turismo.">
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%23004A8F'/><text y='72' x='12' font-size='70'>✈️</text></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
/* ── VARIABLES ── */
:root {
    --bg: #f0f4fa;
    --sidebar-bg: #ffffff;
    --card-bg: #ffffff;
    --text: #1a1e2e;
    --text-muted: #6b7280;
    --border: #e5eaf2;
    --accent: #1a6cff;
    --accent-bg: #eef3ff;
    --shadow: 0 2px 12px rgba(0,0,0,.07);
    --radius: 16px;
    --sidebar-w: 240px;
    --header-h: 64px;
}
[data-theme="dark"] {
    --bg: #0e1120;
    --sidebar-bg: #141829;
    --card-bg: #1a2040;
    --text: #e8edf8;
    --text-muted: #7b86a8;
    --border: rgba(255,255,255,.08);
    --accent: #4d8eff;
    --accent-bg: rgba(77,142,255,.12);
    --shadow: 0 2px 20px rgba(0,0,0,.35);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; width: 100%; overflow-x: hidden; }
body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    transition: background .3s, color .3s;
    font-size: 14px;
    line-height: 1.5;
}

/* ── APP LAYOUT ── */
.app { display: flex; min-height: 100vh; width: 100%; }

/* ── SIDEBAR ── */
.sidebar {
    width: var(--sidebar-w);
    background: var(--sidebar-bg);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0;
    height: 100vh;
    z-index: 100;
    overflow-y: auto;
    transition: background .3s, border .3s;
}
.sidebar-logo {
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
}
.sidebar-logo img { height: 28px; object-fit: contain; }
.sidebar-logo-wordmark { font-size: .7rem; font-weight: 900; color: var(--text); letter-spacing: .5px; line-height: 1.25; }
.sidebar-logo-wordmark small { display: block; font-size: .6rem; font-weight: 600; color: var(--text-muted); letter-spacing: 1px; text-transform: uppercase; }
.sidebar-nav { flex: 1; padding: 10px; }
.nav-item {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 10px 12px;
    border-radius: 10px;
    font-size: .845rem;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    transition: all .18s;
    text-decoration: none;
    white-space: nowrap;
    margin-bottom: 2px;
}
.nav-item i { width: 18px; text-align: center; font-size: .9rem; flex-shrink: 0; }
.nav-item:hover { background: var(--accent-bg); color: var(--accent); }
.nav-item.active { background: var(--accent-bg); color: var(--accent); font-weight: 700; }
.sidebar-bottom { padding: 12px; flex-shrink: 0; }
.sidebar-promo { border-radius: 14px; overflow: hidden; border: 1px solid var(--border); }
.sidebar-promo-img { width: 100%; height: 100px; object-fit: cover; display: block; }
.sidebar-promo-body { padding: 13px; background: var(--card-bg); }
.sidebar-promo h4 { font-size: .78rem; font-weight: 800; color: var(--text); margin-bottom: 4px; }
.sidebar-promo p  { font-size: .7rem; color: var(--text-muted); margin-bottom: 10px; line-height: 1.4; }
.btn-promo { display: block; text-align: center; padding: 8px 12px; background: var(--accent); color: #fff; border-radius: 8px; font-size: .76rem; font-weight: 800; text-decoration: none; transition: .18s; }
.btn-promo:hover { opacity: .85; }

/* ── MAIN WRAPPER ── */
.main-wrap { margin-left: var(--sidebar-w); width: calc(100% - var(--sidebar-w)); display: flex; flex-direction: column; min-height: 100vh; }

/* ── TOP HEADER ── */
.top-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 28px;
    height: var(--header-h);
    background: var(--card-bg);
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 50;
    transition: background .3s;
    flex-shrink: 0;
    width: 100%;
}
.header-left h1 { font-size: 1.05rem; font-weight: 900; color: var(--text); display: flex; align-items: center; gap: 8px; }
.header-left p  { font-size: .7rem; color: var(--text-muted); margin-top: 1px; }
.header-actions { display: flex; align-items: center; gap: 10px; }
.icon-btn {
    width: 36px; height: 36px; border-radius: 50%;
    border: 1.5px solid var(--border);
    background: transparent; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: .9rem; color: var(--text-muted);
    transition: .18s; position: relative;
}
.icon-btn:hover { background: var(--accent-bg); color: var(--accent); border-color: var(--accent); }
.notif-dot { position: absolute; top: 5px; right: 5px; width: 7px; height: 7px; border-radius: 50%; background: #ef4444; border: 2px solid var(--card-bg); }
.user-chip { display: flex; align-items: center; gap: 9px; cursor: pointer; padding: 5px 10px; border-radius: 10px; transition: .18s; }
.user-chip:hover { background: var(--accent-bg); }
.user-avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--accent); display: flex; align-items: center; justify-content: center; color: #fff; font-size: .82rem; font-weight: 800; flex-shrink: 0; overflow: hidden; }
.user-name-lbl { font-size: .83rem; font-weight: 800; color: var(--text); display: block; white-space: nowrap; }
.user-sub-lbl  { font-size: .67rem; color: var(--text-muted); display: block; }
.btn-admin { display: none; font-size: .68rem; padding: 3px 10px; background: var(--accent); color: #fff; border-radius: 6px; text-decoration: none; font-weight: 800; margin-left: 6px; }
.btn-admin.visible { display: inline-flex; align-items: center; gap: 5px; }

/* ── PAGE CONTENT ── */
.page-content { padding: 24px 28px; width: 100%; }

/* ── CHECK-IN BANNER ── */
.checkin-banner {
    display: none;
    background: #fffbeb; border: 1px solid #fcd34d;
    border-radius: 12px; padding: 12px 16px;
    margin-bottom: 18px; align-items: center; gap: 12px; flex-wrap: wrap;
}
.checkin-banner.show { display: flex; }
[data-theme="dark"] .checkin-banner { background: #251f0e; border-color: #7a5c00; }
.btn-checkin { padding: 7px 14px; background: var(--accent); color: #fff; border: none; border-radius: 8px; font-size: .77rem; font-weight: 800; cursor: pointer; }
.btn-dismiss  { background: none; border: none; cursor: pointer; color: var(--text-muted); margin-left: auto; }

/* ── STATES ── */
.state-card { padding: 60px 24px; text-align: center; }
.state-card .state-icon { font-size: 3.2rem; margin-bottom: 18px; }
.state-card h3 { font-size: 1.25rem; font-weight: 900; color: var(--accent); margin-bottom: 12px; }
.state-card p  { color: var(--text-muted); margin-bottom: 24px; }

/* ── HERO BANNER ── */
.hero-banner {
    border-radius: 20px; overflow: hidden;
    position: relative; margin-bottom: 20px;
    min-height: 210px; display: flex; align-items: flex-end;
    background: linear-gradient(135deg, #001a55 0%, #003499 100%);
}
.hero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: .48; }
.hero-overlay { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(0,8,50,.9) 35%, rgba(0,8,50,.06) 100%); }
.hero-body { position: relative; z-index: 1; padding: 26px 30px; flex: 1; }
.hero-label { font-size: .6rem; font-weight: 800; color: rgba(255,255,255,.5); text-transform: uppercase; letter-spacing: 2.5px; margin-bottom: 5px; }
.hero-dest  { font-size: 1.95rem; font-weight: 900; color: #fff; margin-bottom: 14px; line-height: 1.05; }
.hero-meta  { display: flex; align-items: center; gap: 18px; flex-wrap: wrap; }
.hero-dates-chip {
    display: flex; align-items: center; gap: 7px;
    background: rgba(255,255,255,.11); border: 1px solid rgba(255,255,255,.2);
    border-radius: 8px; padding: 5px 11px;
    font-size: .75rem; font-weight: 700; color: rgba(255,255,255,.82);
}
.hero-cd { display: flex; align-items: center; gap: 16px; }
.hero-cd-item { text-align: center; }
.hero-cd-num { font-size: 1.55rem; font-weight: 900; color: #fff; display: block; line-height: 1; font-variant-numeric: tabular-nums; }
.hero-cd-lbl { font-size: .58rem; color: rgba(255,255,255,.48); font-weight: 700; text-transform: uppercase; }
.hero-cta-btn {
    position: absolute; bottom: 22px; right: 24px; z-index: 1;
    display: flex; align-items: center; gap: 7px;
    padding: 9px 18px;
    background: rgba(255,255,255,.13); border: 1.5px solid rgba(255,255,255,.28);
    border-radius: 10px; color: #fff; font-size: .77rem; font-weight: 800;
    cursor: pointer; text-decoration: none; transition: .2s;
}
.hero-cta-btn:hover { background: rgba(255,255,255,.24); }
@keyframes tick-anim { 0%,100%{transform:scale(1)} 50%{transform:scale(1.1)} }
.tick { animation: tick-anim .12s ease; }

/* ── CARDS GRID ── */
.cards-row { display: grid; gap: 16px; margin-bottom: 20px; }
.cols-2 { grid-template-columns: 1fr 1fr; }
.cols-3 { grid-template-columns: 1fr 1fr 1fr; }

/* ── BASE CARD ── */
.card {
    background: var(--card-bg);
    border-radius: var(--radius);
    padding: 22px 24px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    transition: background .3s, border .3s;
}
.card-hdr { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
.card-title { font-size: .88rem; font-weight: 800; color: var(--text); display: flex; align-items: center; gap: 8px; }
.card-link  { font-size: .73rem; font-weight: 700; color: var(--accent); text-decoration: none; display: flex; align-items: center; gap: 4px; white-space: nowrap; }
.card-link:hover { text-decoration: underline; }

/* ── TRIP CARD ── */
.trip-dest-row { display: flex; align-items: center; gap: 14px; margin-bottom: 18px; }
.trip-flag-circle { width: 52px; height: 52px; border-radius: 50%; background: var(--accent-bg); border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 1.7rem; flex-shrink: 0; }
.trip-dest-name  { font-size: 1.4rem; font-weight: 900; color: var(--text); }
.trip-dest-dates { font-size: .72rem; color: var(--text-muted); margin-top: 2px; }
.trip-meta { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 12px; margin-bottom: 18px; }
.trip-meta-item label { font-size: .6rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .8px; display: flex; align-items: center; gap: 4px; margin-bottom: 4px; }
.trip-meta-item span  { font-size: .8rem; font-weight: 800; color: var(--text); }
.trip-action-btn { display: inline-flex; align-items: center; gap: 7px; padding: 9px 16px; border: 1.5px solid var(--border); border-radius: 10px; color: var(--text-muted); font-size: .78rem; font-weight: 700; background: none; cursor: pointer; transition: .18s; }
.trip-action-btn:hover { border-color: var(--accent); color: var(--accent); }

/* ── FIDELIZACIÓN CARD ── */
.fid-tier-header {
    display:flex; align-items:center; gap:14px;
    padding:16px 20px; margin:-22px -24px 18px;
    background:linear-gradient(130deg,#0f2d5e 0%,#1a6cff 60%,#5e3aee 100%);
    border-radius:var(--radius) var(--radius) 0 0;
}
.fid-tier-icon-wrap {
    width:46px; height:46px; border-radius:12px; flex-shrink:0;
    background:rgba(255,255,255,.14); border:1.5px solid rgba(255,255,255,.22);
    display:flex; align-items:center; justify-content:center; font-size:1.45rem;
}
.fid-tier-meta { flex:1; min-width:0; }
.fid-tier-lbl { font-size:.54rem; font-weight:700; color:rgba(255,255,255,.55); text-transform:uppercase; letter-spacing:1.8px; }
.fid-tier-name { font-size:1.15rem; font-weight:900; color:#fff; line-height:1.2; }
.fid-pts-pill { background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.2); border-radius:99px; padding:6px 13px; text-align:center; flex-shrink:0; }
.fid-pts-pill .fid-pts-val { font-size:1.05rem; font-weight:900; color:#fff; display:block; line-height:1; }
.fid-pts-pill .fid-pts-unit { font-size:.52rem; font-weight:700; color:rgba(255,255,255,.5); letter-spacing:1px; text-transform:uppercase; display:block; margin-top:2px; }
.fid-prog-wrap { margin-bottom:14px; }
.fid-prog-labels { display:flex; justify-content:space-between; margin-bottom:6px; font-size:.63rem; font-weight:700; }
.fid-prog-labels span:first-child { color:var(--text-muted); }
.fid-prog-labels span:last-child { color:var(--accent); }
.progress-track { height:6px; background:var(--border); border-radius:99px; overflow:hidden; }
.progress-fill  { height:100%; background:linear-gradient(90deg,var(--accent),#6e44ff); border-radius:99px; width:0; transition:width 1s ease; }
.fid-prog-hint { font-size:.62rem; color:var(--text-muted); margin-top:5px; }
.fid-benefits { display:flex; flex-direction:column; gap:8px; margin-bottom:16px; }
.fid-benefit { display:flex; align-items:center; gap:11px; padding:9px 11px; border-radius:9px; background:var(--accent-bg); }
.fid-benefit-ico { font-size:1.1rem; flex-shrink:0; }
.fid-benefit-name { font-size:.74rem; font-weight:700; color:var(--text); }
.fid-benefit-sub  { font-size:.62rem; color:var(--text-muted); margin-top:1px; }
.fid-benefit.fid-benefit-locked { background:transparent; border:1px dashed var(--border); opacity:.7; }
.fid-action-btn { display:inline-flex; align-items:center; gap:7px; padding:9px 16px; background:var(--accent-bg); border:1.5px solid var(--accent); border-radius:10px; color:var(--accent); font-size:.76rem; font-weight:800; cursor:pointer; transition:.18s; }
.fid-action-btn:hover { background:var(--accent); color:#fff; }

/* ── PASSPORT STAMP CAROUSEL ── */
.stamp-carousel { display: flex; gap: 14px; overflow-x: auto; padding: 4px 0 10px; scrollbar-width: thin; scrollbar-color: var(--border) transparent; }
.stamp-carousel::-webkit-scrollbar { height: 4px; }
.stamp-carousel::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }
.stamp-item { flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 7px; cursor: pointer; }
.stamp-ring {
    width: 80px; height: 80px; border-radius: 50%;
    border: 3px solid;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 1px; position: relative;
    transition: transform .2s, box-shadow .2s;
}
.stamp-ring:hover { transform: scale(1.07); }
.stamp-ring.visited { opacity: 1; }
.stamp-ring.pending { opacity: .32; border-style: dashed; }
.stamp-ring-icon { font-size: 1.85rem; line-height: 1; }
.stamp-ring-year { font-size: .42rem; font-weight: 900; letter-spacing: 1.5px; text-transform: uppercase; position: absolute; bottom: 9px; }
.stamp-lbl-name { font-size: .67rem; font-weight: 700; color: var(--text); text-align: center; max-width: 80px; line-height: 1.25; }
.stamp-lbl-sub  { font-size: .61rem; color: var(--text-muted); text-align: center; }
.stamp-see-all-btn { flex-shrink: 0; width: 80px; height: 80px; border-radius: 50%; border: 2px dashed var(--border); background: transparent; display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; color: var(--text-muted); font-size: .62rem; font-weight: 700; gap: 5px; transition: .18s; }
.stamp-see-all-btn:hover { border-color: var(--accent); color: var(--accent); }
.stamp-blue   { border-color: #1a6cff; color: #1a6cff; }
.stamp-red    { border-color: #dc2626; color: #dc2626; }
.stamp-green  { border-color: #16a34a; color: #16a34a; }
.stamp-purple { border-color: #7c3aed; color: #7c3aed; }
.stamp-orange { border-color: #ea580c; color: #ea580c; }
.stamp-teal   { border-color: #0891b2; color: #0891b2; }

/* ── BOTTOM BANNER ── */
.bottom-banner { border-radius: 16px; padding: 22px 28px; display: flex; align-items: center; justify-content: space-between; gap: 20px; background: linear-gradient(130deg, #0f2290, var(--accent), #4d2aff); flex-wrap: wrap; margin-bottom: 24px; }
.bottom-banner h4 { font-size: .95rem; font-weight: 900; color: #fff; margin-bottom: 4px; }
.bottom-banner p  { font-size: .75rem; color: rgba(255,255,255,.7); }
.bottom-banner-btn { display: flex; align-items: center; gap: 8px; padding: 11px 22px; background: rgba(255,255,255,.14); border: 1.5px solid rgba(255,255,255,.3); border-radius: 10px; color: #fff; font-size: .8rem; font-weight: 800; cursor: pointer; white-space: nowrap; flex-shrink: 0; transition: .2s; }
.bottom-banner-btn:hover { background: rgba(255,255,255,.26); }

/* ── PASSPORT MODAL ── */
.passport-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.65); backdrop-filter: blur(10px); z-index: 300; align-items: center; justify-content: center; padding: 20px; }
.passport-modal-overlay.open { display: flex; }
.passport-modal-inner { background: var(--card-bg); border-radius: 20px; max-width: 560px; width: 100%; max-height: 88vh; overflow: hidden; display: flex; flex-direction: column; box-shadow: 0 24px 80px rgba(0,0,0,.35); animation: modalIn .28s cubic-bezier(.175,.885,.32,1.275); }
@keyframes modalIn { from { opacity:0; transform:scale(.92) translateY(20px); } to { opacity:1; transform:none; } }
.pmodal-header { padding: 18px 22px 14px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
.pmodal-title  { font-size: .95rem; font-weight: 900; color: var(--text); display: flex; align-items: center; gap: 8px; }
.pmodal-close  { width: 32px; height: 32px; border-radius: 50%; border: 1.5px solid var(--border); background: transparent; cursor: pointer; color: var(--text-muted); font-size: .85rem; display: flex; align-items: center; justify-content: center; transition: .18s; }
.pmodal-close:hover { background: var(--accent-bg); color: var(--accent); }
.pmodal-tabs { display: flex; gap: 6px; padding: 12px 22px 0; flex-shrink: 0; overflow-x: auto; scrollbar-width: none; }
.pmodal-tabs::-webkit-scrollbar { display: none; }
.pmodal-tab { padding: 6px 13px; border-radius: 8px; font-size: .76rem; font-weight: 700; color: var(--text-muted); background: none; border: 1.5px solid transparent; cursor: pointer; white-space: nowrap; transition: .18s; }
.pmodal-tab:hover:not(.active) { background: var(--accent-bg); color: var(--accent); }
.pmodal-tab.active { background: var(--accent-bg); color: var(--accent); border-color: var(--accent); }
.pmodal-body  { overflow-y: auto; flex: 1; padding: 14px 22px 22px; }
.pmodal-country-header { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; font-size: .82rem; font-weight: 800; color: var(--text); }
.pmodal-st-row { display: flex; align-items: center; justify-content: space-between; padding: 9px 10px; border-radius: 9px; transition: .15s; }
.pmodal-st-row:hover { background: var(--accent-bg); }
.pmodal-st-name { font-size: .81rem; font-weight: 700; color: var(--text); }
.pmodal-st-team { font-size: .67rem; color: var(--text-muted); margin-top: 1px; }
.pmodal-visited-lbl { font-size: .71rem; font-weight: 800; color: #16a34a; display: flex; align-items: center; gap: 4px; }
.pmodal-pending-lbl { font-size: .67rem; color: var(--text-muted); }
.btn-sellar-modal { font-size: .7rem; font-weight: 800; padding: 5px 12px; background: var(--accent); color: #fff; border: none; border-radius: 7px; cursor: pointer; transition: .18s; }
.btn-sellar-modal:hover { opacity: .85; }
.btn-sellar-modal:disabled { opacity: .5; cursor: not-allowed; }

/* ── RECENT TRIPS ── */
.recent-trip-item { display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:1px solid var(--border); }
.recent-trip-item:last-child { border-bottom:none; padding-bottom:0; }
.rtrip-thumb { width:44px; height:36px; border-radius:8px; background:var(--accent-bg); display:flex; align-items:center; justify-content:center; font-size:1.15rem; flex-shrink:0; }
.rtrip-name  { font-size:.82rem; font-weight:700; color:var(--text); }
.rtrip-dates { font-size:.66rem; color:var(--text-muted); margin-top:1px; }
.rtrip-badge { font-size:.6rem; font-weight:800; padding:2px 7px; border-radius:20px; background:#dcfce7; color:#16a34a; flex-shrink:0; }
[data-theme="dark"] .rtrip-badge { background:rgba(22,163,74,.15); }

/* ── PASSPORT COVER CARD ── */
.pcover-card { display:flex; align-items:center; gap:14px; perspective:900px; }
.pcover {
    width:64px; height:90px; border-radius:3px 8px 8px 3px;
    display:flex; flex-direction:column; align-items:center; justify-content:space-between;
    padding:8px 6px 7px; position:relative; flex-shrink:0; cursor:pointer;
    box-shadow:-3px 5px 14px rgba(0,0,0,.52), -6px 1px 0 rgba(0,0,0,.18), inset 1px 0 0 rgba(255,255,255,.16);
    border-left:6px solid rgba(0,0,0,.3);
    overflow:hidden;
    transform: rotate(-3deg) translateY(2px);
    transition: transform 250ms ease-in-out, box-shadow 250ms ease-in-out;
}
.pcover:hover {
    transform: scale(1.06) rotate(-2deg) translateY(-4px);
    box-shadow: -5px 10px 22px rgba(0,0,0,.65), -8px 2px 0 rgba(0,0,0,.22), inset 1px 0 0 rgba(255,255,255,.22);
}
.pcover:active {
    transform: scale(0.97) rotate(-3deg) translateY(2px);
    transition-duration: 80ms;
}
.pcover::after {
    content:''; position:absolute; inset:0;
    background:linear-gradient(120deg,rgba(255,255,255,.32) 0%,rgba(255,255,255,.06) 35%,transparent 55%,rgba(0,0,0,.15) 100%);
    pointer-events:none; border-radius:inherit;
}
.pcover.green  { background:linear-gradient(160deg,#174f28 0%,#2d8a45 55%,#1d6635 100%); }
.pcover.purple { background:linear-gradient(160deg,#38155a 0%,#6b2fa0 55%,#461a76 100%); }
.pcover-wm { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-size:2.5rem; opacity:.07; pointer-events:none; }
.pcover-top  { font-size:.36rem; font-weight:900; color:rgba(255,255,255,.9); text-transform:uppercase; letter-spacing:1px; text-align:center; line-height:1.7; }
.pcover-icon { font-size:1.2rem; filter:drop-shadow(0 2px 8px rgba(0,0,0,.45)); margin:1px 0; }
.pcover-brand{ font-size:.36rem; font-weight:900; color:rgba(255,255,255,.65); text-transform:uppercase; letter-spacing:1.5px; border-top:1px solid rgba(255,255,255,.28); padding-top:3px; width:100%; text-align:center; }
.pcover-info { flex:1; min-width:0; }
.pcover-info h3 { font-size:.9rem; font-weight:800; color:var(--text); margin-bottom:4px; }
.pcover-info p  { font-size:.7rem; color:var(--text-muted); margin-bottom:12px; line-height:1.45; }
.pcover-stat-lbl{ font-size:.65rem; font-weight:700; color:var(--text-muted); margin-bottom:4px; }
.pcover-stat-val{ font-size:.78rem; font-weight:800; color:var(--text); }
.pcover-bar { height:5px; background:var(--border); border-radius:99px; margin:6px 0 14px; overflow:hidden; }
.pcover-bar-fill{ height:100%; border-radius:99px; transition:width .7s ease; }
.pcover-bar-fill.green { background:linear-gradient(90deg,#22c55e,#16a34a); }
.pcover-bar-fill.blue  { background:linear-gradient(90deg,#60a5fa,#3b82f6); }
.btn-ver-pasaporte { display:flex; align-items:center; gap:7px; width:100%; padding:9px 14px; background:var(--accent-bg); color:var(--accent); border:1.5px solid var(--accent); border-radius:9px; font-size:.76rem; font-weight:800; cursor:pointer; transition:.18s; justify-content:center; }
.btn-ver-pasaporte:hover { background:var(--accent); color:#fff; }

/* ── PASAPORTE LIBRO ── */
.page {
    flex:1; padding:22px 20px; position:relative; overflow-y:auto;
    background:repeating-linear-gradient(to bottom,#f5ebdd,#f5ebdd 27px,#e9dcc8 28px);
}
.page.left-page { border-right:3px solid rgba(160,132,80,.22); box-shadow:inset -6px 0 12px rgba(0,0,0,.04); }
[data-theme="dark"] .page { background:repeating-linear-gradient(to bottom,#1c2235,#1c2235 27px,#181c2c 28px); }
[data-theme="dark"] .page.left-page { border-right-color:rgba(255,255,255,.07); box-shadow:none; }
.page-title { font-size:.56rem; font-weight:900; text-transform:uppercase; letter-spacing:2.2px; color:#8b7d6b; margin-bottom:16px; padding-bottom:8px; border-bottom:1px solid rgba(150,120,70,.2); }
[data-theme="dark"] .page-title { color:var(--text-muted); border-bottom-color:rgba(255,255,255,.07); }
/* país / item */
.country {
    position:relative; padding:10px 14px; margin-bottom:10px;
    border-radius:10px; background:rgba(255,255,255,.42);
    display:flex; align-items:center; gap:12px;
    transition:transform .2s, background .18s;
}
.country:hover { transform:scale(1.02); background:rgba(255,255,255,.6); }
.country.stamped { background:rgba(255,255,255,.68); }
[data-theme="dark"] .country { background:rgba(255,255,255,.06); }
[data-theme="dark"] .country:hover { background:rgba(255,255,255,.1); }
[data-theme="dark"] .country.stamped { background:rgba(255,255,255,.12); }
.country-flag-emoji { font-size:1.5rem; flex-shrink:0; line-height:1; }
.country-body { flex:1; min-width:0; }
.code { font-weight:900; font-size:.78rem; color:#5c5346; letter-spacing:.8px; display:block; }
.name { font-size:.73rem; color:#7a6f60; display:block; margin-top:2px; }
[data-theme="dark"] .code { color:var(--text); }
[data-theme="dark"] .name { color:var(--text-muted); }
.stamp-btn {
    padding:5px 12px; border-radius:7px;
    border:1.5px solid #b8a98c; background:transparent;
    font-size:.65rem; font-weight:700; cursor:pointer; white-space:nowrap; flex-shrink:0;
    transition:all .16s;
}
.stamp-btn:hover:not(:disabled) { background:#e7dcc6; transform:scale(1.05); }
.stamp-btn:active:not(:disabled) { transform:scale(.93); }
.stamp-btn:disabled { opacity:.5; cursor:not-allowed; }
.stamp-btn.done { background:#dcfce7; border-color:#16a34a; color:#16a34a; font-weight:800; }
/* sello de tinta */
.stamp {
    position:absolute; top:8px; right:10px;
    font-size:.7rem; font-weight:900; letter-spacing:1.2px;
    color:rgba(155,28,28,.8); border:2px solid rgba(155,28,28,.65);
    padding:2px 7px; border-radius:5px;
    transform:rotate(-12deg); pointer-events:none;
    animation:stampHit .36s ease-out;
}
@keyframes stampHit {
    0%   { transform:translateY(-36px) scale(1.45) rotate(-12deg); opacity:0; }
    60%  { transform:translateY(0)     scale(.88)  rotate(-12deg); }
    80%  { transform:translateY(-2px)  scale(1.04) rotate(-12deg); }
    100% { transform:scale(1) rotate(-12deg); opacity:1; }
}
/* estadio (futbolero) */
.stadium {
    position:relative; display:flex; justify-content:space-between;
    align-items:center; padding:11px 14px; margin-bottom:8px;
    background:rgba(255,255,255,.46); border-radius:10px;
    transition:transform .18s, background .18s;
}
.stadium:hover { transform:scale(1.015); background:rgba(255,255,255,.68); }
.stadium.stamped { background:rgba(255,255,255,.72); }
[data-theme="dark"] .stadium { background:rgba(255,255,255,.07); }
[data-theme="dark"] .stadium:hover { background:rgba(255,255,255,.12); }
.stadium-info { display:flex; gap:10px; align-items:center; flex:1; min-width:0; }
.stadium-icon { font-size:1.45rem; flex-shrink:0; }
.stadium-name { font-size:.8rem; font-weight:800; color:#3a2e1a; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.stadium-club { font-size:.63rem; color:#9a8060; margin-top:2px; }
[data-theme="dark"] .stadium-name { color:var(--text); }
[data-theme="dark"] .stadium-club { color:var(--text-muted); }

/* ── QUICK ACTIONS ── */
.quick-actions { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:20px; }
.qa-item { display:flex; align-items:center; gap:12px; padding:14px 16px; background:var(--card-bg); border-radius:var(--radius); border:1px solid var(--border); box-shadow:var(--shadow); cursor:pointer; transition:.18s; text-decoration:none; }
.qa-item:hover { border-color:var(--accent); transform:translateY(-2px); box-shadow:0 6px 20px rgba(26,108,255,.1); }
.qa-ico { width:38px; height:38px; border-radius:10px; background:var(--accent-bg); display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0; }
.qa-title { font-size:.79rem; font-weight:800; color:var(--text); }
.qa-sub   { font-size:.64rem; color:var(--text-muted); margin-top:2px; }

/* ── PASSPORT MODAL OVERLAY ── */
.passport-modal {
    position:fixed; inset:0; z-index:300;
    backdrop-filter:blur(14px) saturate(1.5);
    background:rgba(0,0,0,.38);
    display:flex; align-items:center; justify-content:center;
    opacity:0; pointer-events:none; transition:opacity .32s;
}
.passport-modal.open { opacity:1; pointer-events:all; }
/* 3D wrapper */
.passport-3d {
    width:min(940px,96vw); height:min(560px,86vh);
    position:relative; transform-style:preserve-3d; perspective:2200px;
}
/* COVER (tapa que se abre) */
.passport-cover {
    position:absolute; inset:0;
    background:linear-gradient(155deg,#174f28 0%,#2d8a45 55%,#1d6635 100%);
    border-radius:18px;
    display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px;
    color:#fff; transform-origin:left center;
    transition:transform .84s cubic-bezier(.645,.045,.355,1), box-shadow .84s;
    z-index:2;
    box-shadow:-8px 12px 40px rgba(0,0,0,.55), 0 2px 0 rgba(255,255,255,.08) inset;
}
.passport-cover .cover-emblem { font-size:3.2rem; filter:drop-shadow(0 3px 10px rgba(0,0,0,.4)); }
.passport-cover h2 { font-size:1.5rem; font-weight:900; letter-spacing:5px; text-transform:uppercase; margin:0; }
.passport-cover .cover-sub { font-size:.62rem; font-weight:700; letter-spacing:4px; opacity:.6; margin:0; }
.passport-3d.futbol .passport-cover { background:linear-gradient(155deg,#38155a 0%,#6b2fa0 55%,#461a76 100%); }
.passport-3d.open .passport-cover {
    transform:rotateY(-168deg);
    box-shadow:0 0 0 rgba(0,0,0,0);
}
/* INTERIOR */
.passport-book {
    position:absolute; inset:0;
    display:flex; flex-direction:column;
    background:#f5ebdd; border-radius:18px; overflow:hidden;
    box-shadow:0 32px 80px rgba(0,0,0,.45);
}
[data-theme="dark"] .passport-book { background:#1c2235; }
/* header del libro */
.book-header {
    display:flex; align-items:center; justify-content:space-between;
    padding:13px 20px 11px; border-bottom:1px solid rgba(155,130,80,.22);
    background:rgba(250,246,230,.95); flex-shrink:0;
}
[data-theme="dark"] .book-header { background:var(--sidebar-bg); border-bottom-color:var(--border); }
.book-ttl { font-size:.9rem; font-weight:800; color:#3a2e1a; display:flex; align-items:center; gap:8px; }
[data-theme="dark"] .book-ttl { color:var(--text); }
.book-close-btn {
    width:28px; height:28px; border-radius:50%;
    border:1.5px solid rgba(155,130,80,.3); background:transparent;
    cursor:pointer; font-size:.9rem; color:#9a8060;
    display:flex; align-items:center; justify-content:center; transition:.15s;
}
.book-close-btn:hover { background:#ede3ce; color:#5a3e1a; }
[data-theme="dark"] .book-close-btn { border-color:var(--border); color:var(--text-muted); }
/* league tabs */
.league-tabs {
    display:flex; gap:4px; padding:8px 14px 0; flex-shrink:0;
    border-bottom:1px solid rgba(155,130,80,.2); overflow-x:auto; scrollbar-width:none;
    background:rgba(243,236,218,.9);
}
.league-tabs::-webkit-scrollbar { display:none; }
[data-theme="dark"] .league-tabs { background:var(--sidebar-bg); border-bottom-color:var(--border); }
.league-tab-btn {
    padding:5px 12px 10px; border:none; background:transparent;
    font-size:.7rem; font-weight:700; color:#9a8060; cursor:pointer;
    border-bottom:2.5px solid transparent; transition:.15s; white-space:nowrap; flex-shrink:0;
}
.league-tab-btn.active { color:#3a2e1a; border-bottom-color:#5c4a2a; }
.league-tab-btn:hover:not(.active) { color:#5c4a2a; }
[data-theme="dark"] .league-tab-btn { color:var(--text-muted); }
[data-theme="dark"] .league-tab-btn.active { color:var(--accent); border-bottom-color:var(--accent); }
/* body (páginas) */
.book-body { flex:1; display:flex; overflow:hidden; position:relative; }
.book-body.anim-fwd { animation:bookFwd .25s ease; }
.book-body.anim-bck { animation:bookBck .25s ease; }
@keyframes bookFwd { from{opacity:0;transform:translateX(16px)} to{opacity:1;transform:none} }
@keyframes bookBck { from{opacity:0;transform:translateX(-16px)} to{opacity:1;transform:none} }
.book-pages { display:flex; width:100%; position:relative; }
/* pliegue central */
.book-pages::before {
    content:''; position:absolute; left:50%; transform:translateX(-50%);
    width:5px; height:100%; background:rgba(0,0,0,.07);
    z-index:1; pointer-events:none;
}
/* nav */
.book-nav {
    display:flex; align-items:center; justify-content:center; gap:14px;
    padding:9px; border-top:1px solid rgba(155,130,80,.2);
    background:rgba(237,227,206,.85); flex-shrink:0;
}
[data-theme="dark"] .book-nav { background:var(--sidebar-bg); border-top-color:var(--border); }
.book-nav-btn {
    width:28px; height:28px; border-radius:50%; border:1.5px solid #c5b89a;
    background:transparent; cursor:pointer; font-size:1rem; font-weight:700;
    color:#8a7b60; display:flex; align-items:center; justify-content:center; transition:.15s;
}
.book-nav-btn:hover:not(:disabled) { border-color:var(--accent); color:var(--accent); transform:scale(1.1); }
.book-nav-btn:disabled { opacity:.3; cursor:not-allowed; }
.book-nav-lbl { font-size:.7rem; font-weight:700; color:#9a8060; min-width:38px; text-align:center; }
[data-theme="dark"] .book-nav-btn { border-color:var(--border); color:var(--text-muted); }
[data-theme="dark"] .book-nav-lbl { color:var(--text-muted); }

/* ── MICROINTERACCIONES ── */
.btn-ver-pasaporte { transition: transform .16s ease, background .18s, color .18s, border-color .18s !important; }
.btn-ver-pasaporte:hover:not(:disabled) { transform: scale(1.04); }
.btn-ver-pasaporte:active:not(:disabled) { transform: scale(0.95); }
.stamp-btn { transition: transform .14s ease, all .18s !important; }
.book-nav-btn { transition: transform .12s ease, border-color .18s, color .18s, background .18s !important; }
.league-tab-btn { transition: transform .12s ease, background .18s, color .18s, border-color .18s !important; }
.league-tab-btn:hover:not(.active) { transform: translateY(-1px); }
.league-tab-btn:active { transform: scale(0.95); }

/* ── RESPONSIVE ── */
@media (max-width: 1100px) {
    .cols-3 { grid-template-columns: 1fr 1fr; }
    .quick-actions { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 860px) {
    .cols-2, .cols-3 { grid-template-columns: 1fr; }
    .trip-meta { grid-template-columns: 1fr 1fr; }
    .quick-actions { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 700px) {
    .sidebar { display: none; }
    .main-wrap { margin-left: 0; width: 100%; }
    .page-content { padding: 14px; }
    .hero-dest { font-size: 1.45rem; }
    .hero-cta-btn { display: none; }
    .top-header { padding: 0 16px; }
    .quick-actions { grid-template-columns: 1fr 1fr; }
    .pcover-card { gap:12px; }
    .pcover { width:88px; height:125px; }
}
    </style>
</head>
<body>
<div class="app">

    <!-- ══════════════ SIDEBAR ══════════════ -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <img src="../assets/logo-web.png" alt="Herse" onerror="this.style.display='none'">
        </div>
        <nav class="sidebar-nav">
            <a class="nav-item active" href="/mi-viaje">
                <i class="fas fa-plane"></i> Mi Viaje
            </a>
            <a class="nav-item" href="#historialSection">
                <i class="fas fa-suitcase"></i> Mis Viajes
            </a>
            <a class="nav-item" href="#" onclick="return false">
                <i class="fas fa-passport"></i> Pasaporte de Viaje
            </a>
            <a class="nav-item" href="#" onclick="openPassportModal(); return false">
                <i class="fas fa-futbol"></i> Pasaporte Futbolero
            </a>
            <a class="nav-item" href="#fidSection">
                <i class="fas fa-star"></i> Fidelización Herse
            </a>
            <a class="nav-item" href="/">
                <i class="fas fa-tag"></i> Ofertas para vos
            </a>
            <a class="nav-item" href="#">
                <i class="fas fa-user"></i> Mi Perfil
            </a>
            <a class="nav-item" href="https://wa.me/5492215661704" target="_blank" rel="noopener">
                <i class="fas fa-headset"></i> Ayuda y Soporte
            </a>
        </nav>
        <div class="sidebar-bottom">
            <div class="sidebar-promo">
                <img class="sidebar-promo-img"
                     src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=400&q=80"
                     alt="" onerror="this.style.display='none'">
                <div class="sidebar-promo-body">
                    <h4>¿Listo para tu próximo destino?</h4>
                    <p>Explorá nuestras ofertas exclusivas.</p>
                    <a href="/" class="btn-promo">Ver ofertas</a>
                </div>
            </div>
        </div>
    </aside>

    <!-- ══════════════ MAIN ══════════════ -->
    <div class="main-wrap">

        <!-- TOP HEADER -->
        <header class="top-header">
            <div class="header-left">
                <h1>
                    Mi Viaje ✈️
                    <a href="/admin" class="btn-admin" id="btnAdmin">
                        <i class="fas fa-shield-alt"></i> Admin
                    </a>
                </h1>
                <p>Tu mundo, tus viajes, tu historia.</p>
            </div>
            <div class="header-actions">
                <button class="icon-btn" onclick="toggleTheme()" id="themeBtn" title="Cambiar tema">🌙</button>
                <button class="icon-btn" title="Notificaciones">
                    <i class="fas fa-bell"></i>
                    <span class="notif-dot"></span>
                </button>
                <div class="user-chip" onclick="logout()" title="Cerrar sesión">
                    <div class="user-avatar">
                        <span style="font-size:.8rem;font-weight:900" id="avatarInitial">V</span>
                    </div>
                    <div>
                        <span class="user-name-lbl name">Viajero</span>
                        <span class="user-sub-lbl">Ver perfil</span>
                    </div>
                    <i class="fas fa-chevron-down" style="font-size:.62rem;color:var(--text-muted)"></i>
                </div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <div class="page-content">

            <!-- CHECK-IN BANNER -->
            <div class="checkin-banner" id="checkinBanner">
                <span style="font-size:1.1rem">⏰</span>
                <div style="flex:1;font-size:.82rem">
                    <strong>¡Recordatorio de check-in!</strong>
                    <span id="checkinBannerText"> No olvides hacer el check-in online.</span>
                </div>
                <button class="btn-checkin" id="btnCheckinDo">Hacer check-in</button>
                <button class="btn-dismiss" onclick="dismissCheckin()"><i class="fas fa-times"></i></button>
            </div>

            <!-- PENDING STATE -->
            <div id="pendingState" style="display:none" class="state-card">
                <div class="state-icon">✈️</div>
                <h3>¡Tu portal está casi listo!</h3>
                <p>Tu consultor ya está preparando la información de tu viaje.</p>
                <a href="https://wa.me/5492215661704" target="_blank" rel="noopener"
                   style="display:inline-flex;align-items:center;gap:10px;background:#25D366;color:#fff;padding:12px 26px;border-radius:50px;font-weight:800;font-size:.9rem;text-decoration:none">
                    <i class="fab fa-whatsapp"></i> Consultar
                </a>
            </div>

            <!-- PRÓXIMAMENTE -->
            <div id="proximamente" style="display:none" class="state-card">
                <div class="state-icon">🌍</div>
                <h3>¡Próximamente!</h3>
                <p>Estamos preparando algo especial para vos.</p>
            </div>

            <!-- ══ MAIN DASHBOARD ══ -->
            <div id="mainDashboard">

                <!-- HERO BANNER -->
                <div class="hero-banner">
                    <img class="hero-img" id="heroBannerImg"
                         src="https://images.unsplash.com/photo-1483729558449-99ef09a8c325?w=1200&q=80" alt="">
                    <div class="hero-overlay"></div>
                    <div class="hero-body">
                        <div class="hero-label">Tu próxima aventura</div>
                        <div class="hero-dest">
                            <span id="cardTripDest">Tu Destino</span> te espera ✈️
                        </div>
                        <div class="hero-meta">
                            <div class="hero-dates-chip">
                                <i class="fas fa-calendar-alt" style="opacity:.65"></i>
                                <span class="countdown-footer">—</span>
                            </div>
                            <div class="hero-cd">
                                <div class="hero-cd-item">
                                    <span class="hero-cd-num" id="cd-d">00</span>
                                    <span class="hero-cd-lbl">días</span>
                                </div>
                                <div class="hero-cd-item">
                                    <span class="hero-cd-num" id="cd-h">00</span>
                                    <span class="hero-cd-lbl">horas</span>
                                </div>
                                <div class="hero-cd-item">
                                    <span class="hero-cd-num" id="cd-m">00</span>
                                    <span class="hero-cd-lbl">min</span>
                                </div>
                                <div class="hero-cd-item">
                                    <span class="hero-cd-num" id="cd-s">00</span>
                                    <span class="hero-cd-lbl">seg</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <a href="#" class="hero-cta-btn">
                        Ver detalles del viaje <i class="fas fa-chevron-right"></i>
                    </a>
                </div>

                <!-- ROW 1: VIAJE + FIDELIZACIÓN + RECIENTES -->
                <div class="cards-row cols-3">

                    <!-- VIAJE CARD -->
                    <div class="card">
                        <div class="card-hdr">
                            <span class="card-title">
                                <i class="fas fa-plane" style="color:var(--accent)"></i>
                                Tu viaje actual
                            </span>
                            <a href="#" class="card-link">Ver itinerario <i class="fas fa-chevron-right"></i></a>
                        </div>
                        <div class="trip-dest-row">
                            <div class="trip-flag-circle" id="tripFlagCircle">🌍</div>
                            <div>
                                <div class="trip-dest-name" id="mosaicTripDest">—</div>
                                <div class="trip-dest-dates countdown-footer">—</div>
                            </div>
                        </div>
                        <div class="trip-meta">
                            <div class="trip-meta-item">
                                <label><i class="fas fa-clock"></i> Salida</label>
                                <span class="mt-val-salida">—</span>
                            </div>
                            <div class="trip-meta-item">
                                <label><i class="fas fa-map-pin"></i> Regreso</label>
                                <span class="mt-val-regreso">—</span>
                            </div>
                            <div class="trip-meta-item">
                                <label><i class="fas fa-users"></i> Pasajeros</label>
                                <span class="mt-val-pax">—</span>
                            </div>
                            <div class="trip-meta-item">
                                <label><i class="fas fa-hotel"></i> Hotel</label>
                                <span class="mt-val-hotel">—</span>
                            </div>
                        </div>
                        <button class="trip-action-btn">
                            Ver itinerario completo <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>

                    <!-- FIDELIZACIÓN CARD -->
                    <div class="card" id="fidSection">
                        <div class="fid-tier-header">
                            <div class="fid-tier-icon-wrap" id="fidTierBadge"><span>🌱</span></div>
                            <div class="fid-tier-meta">
                                <div class="fid-tier-lbl">Nivel Herse</div>
                                <div class="fid-tier-name" id="fidLevelLabel">Explorador</div>
                            </div>
                            <div class="fid-pts-pill">
                                <span class="fid-pts-val" id="fidCountLabel">0</span>
                                <span class="fid-pts-unit">pts</span>
                            </div>
                        </div>
                        <div class="fid-prog-wrap">
                            <div class="fid-prog-labels">
                                <span id="fidCurrentTierLbl">Explorador</span>
                                <span id="fidNextTier">&#8594; Viajero</span>
                            </div>
                            <div class="progress-track">
                                <div class="progress-fill" id="loyaltyBar"></div>
                            </div>
                            <div class="fid-prog-hint" id="fidProgHint">Completá 3 viajes para subir de nivel</div>
                        </div>
                        <div class="fid-benefits">
                            <div class="fid-benefit">
                                <span class="fid-benefit-ico">🏷️</span>
                                <div>
                                    <div class="fid-benefit-name">5% de descuento</div>
                                    <div class="fid-benefit-sub">En tu próxima reserva</div>
                                </div>
                            </div>
                            <div class="fid-benefit">
                                <span class="fid-benefit-ico">💬</span>
                                <div>
                                    <div class="fid-benefit-name">Soporte prioritario</div>
                                    <div class="fid-benefit-sub">Atención directa por WhatsApp</div>
                                </div>
                            </div>
                            <div class="fid-benefit fid-benefit-locked">
                                <span class="fid-benefit-ico">🔒</span>
                                <div>
                                    <div class="fid-benefit-name" id="fidNextBenefit">Check-in anticipado</div>
                                    <div class="fid-benefit-sub" id="fidNextBenefitSub">Disponible desde nivel Viajero</div>
                                </div>
                            </div>
                        </div>
                        <button class="fid-action-btn">
                            Ver beneficios completos <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>

                    <!-- VIAJES RECIENTES -->
                    <div class="card">
                        <div class="card-hdr">
                            <span class="card-title"><i class="fas fa-history" style="color:var(--accent)"></i> Viajes recientes</span>
                            <a href="#" class="card-link">Ver todos <i class="fas fa-chevron-right"></i></a>
                        </div>
                        <div id="recentTrips">
                            <div style="color:var(--text-muted);font-size:.8rem;padding:22px 0;text-align:center">
                                Sin viajes completados aún
                            </div>
                        </div>
                        <button class="trip-action-btn" style="margin-top:auto">
                            Ver todos mis viajes <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>

                </div>

                <!-- ROW 2: PASAPORTES -->
                <div class="cards-row cols-2">

                    <!-- PASAPORTE DE VIAJE -->
                    <div class="card">
                        <div class="pcover-card">
                            <div class="pcover green" onclick="openViajeModal()">
                                <div class="pcover-wm">🌍</div>
                                <div class="pcover-top">PASAPORTE<br>DE VIAJE</div>
                                <div class="pcover-icon">🌍</div>
                                <div class="pcover-brand">✶ HERSE</div>
                            </div>
                            <div class="pcover-info">
                                <h3>Pasaporte de Viaje</h3>
                                <p>Sellá tus destinos y coleccióná experiencias inolvidables.</p>
                                <div class="pcover-stat-lbl">Sellos obtenidos</div>
                                <div class="pcover-stat-val" id="viajeSellosLbl">0 / 28</div>
                                <div class="pcover-bar">
                                    <div class="pcover-bar-fill green" id="viajeProgressBar" style="width:0%"></div>
                                </div>
                                <button class="btn-ver-pasaporte" onclick="openViajeModal()">
                                    <i class="fas fa-passport"></i> Ver pasaporte
                                    <i class="fas fa-lock" style="margin-left:auto;font-size:.6rem;opacity:.55"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- PASAPORTE FUTBOLERO -->
                    <div class="card" id="passportSection">
                        <div class="pcover-card">
                            <div class="pcover purple" onclick="openFutbolModal()">
                                <div class="pcover-wm">⚽</div>
                                <div class="pcover-top">PASAPORTE<br>FUTBOLERO</div>
                                <div class="pcover-icon">⚽</div>
                                <div class="pcover-brand">✶ HERSE</div>
                            </div>
                            <div class="pcover-info">
                                <h3>Pasaporte Futbolero</h3>
                                <p>Explorá estadios, viví pasiones y dejá tu huella en cada cancha.</p>
                                <div class="pcover-stat-lbl">Estadios visitados</div>
                                <div class="pcover-stat-val" id="futbolSellosLbl">0 / 35</div>
                                <div class="pcover-bar">
                                    <div class="pcover-bar-fill blue" id="futbolProgressBar" style="width:0%"></div>
                                </div>
                                <button class="btn-ver-pasaporte" onclick="openFutbolModal()">
                                    <i class="fas fa-futbol"></i> Ver pasaporte
                                    <i class="fas fa-lock" style="margin-left:auto;font-size:.6rem;opacity:.55"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- HISTORIAL (fuente de datos) -->
                <div id="historialSection" style="display:none">
                    <div id="historialList"></div>
                </div>

                <!-- QUICK ACTIONS -->
                <div class="quick-actions">
                    <a href="#" class="qa-item">
                        <div class="qa-ico">📍</div>
                        <div><div class="qa-title">Explorar destinos</div><div class="qa-sub">Descubrí tu próximo destino</div></div>
                    </a>
                    <a href="https://wa.me/5492215661704" target="_blank" class="qa-item">
                        <div class="qa-ico">🏷️</div>
                        <div><div class="qa-title">Ofertas exclusivas</div><div class="qa-sub">Descuentos para vos</div></div>
                    </a>
                    <a href="#" class="qa-item">
                        <div class="qa-ico">📅</div>
                        <div><div class="qa-title">Agregar viaje</div><div class="qa-sub">Tenés todo organizado</div></div>
                    </a>
                    <a href="https://wa.me/5492215661704" target="_blank" class="qa-item">
                        <div class="qa-ico">👥</div>
                        <div><div class="qa-title">Invitar amigos</div><div class="qa-sub">Viajá más, juntos</div></div>
                    </a>
                </div>

            </div><!-- /mainDashboard -->

        </div><!-- /page-content -->
    </div><!-- /main-wrap -->

</div><!-- /app -->

<!-- VIAJE PASSPORT MODAL -->
<div class="passport-modal" id="viajeModalOverlay" onclick="if(event.target===this)closeViajeModal()">
    <div class="passport-3d" id="passportViaje3d">
        <div class="passport-cover">
            <span class="cover-emblem">🌍</span>
            <h2>PASAPORTE</h2>
            <p class="cover-sub">HERSE TURISMO</p>
        </div>
        <div class="passport-book">
            <div class="book-header">
                <div class="book-ttl"><i class="fas fa-passport" style="color:#22c55e"></i> Pasaporte de Viaje <span id="viajeModalCount" style="font-size:.68rem;font-weight:600;color:#9a8060;margin-left:4px">0 / 28</span></div>
                <button class="book-close-btn" onclick="closeViajeModal()">&#10005;</button>
            </div>
            <div class="book-body" id="viajeSpread"></div>
            <div class="book-nav">
                <button class="book-nav-btn" id="viajeNavPrev" onclick="navViajePassport(-1)">&#8249;</button>
                <span class="book-nav-lbl" id="viajeNavLbl">1 / 3</span>
                <button class="book-nav-btn" id="viajeNavNext" onclick="navViajePassport(1)">&#8250;</button>
