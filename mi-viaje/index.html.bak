    <div class="passport-3d futbol" id="passportFutbol3d">
        <div class="passport-cover">
            <span class="cover-emblem">⚽</span>
            <h2>PASAPORTE</h2>
            <p class="cover-sub">FUTBOLERO</p>
        </div>
        <div class="passport-book">
            <div class="book-header">
                <div class="book-ttl"><i class="fas fa-futbol" style="color:var(--accent)"></i> Pasaporte Futbolero <span id="pasaporteCount" style="font-size:.68rem;font-weight:600;color:#9a8060;margin-left:4px">0 / 35</span></div>
                <button class="book-close-btn" onclick="closeFutbolModal()">&#10005;</button>
            </div>
            <div class="league-tabs" id="futbolTabs"></div>
            <div class="book-body" id="futbolSpread"></div>
